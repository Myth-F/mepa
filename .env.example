# MEPA environment configuration — NAMES AND DOCUMENTATION ONLY.
# Copy to `.env`, fill in real values, and keep `.env` out of version control.
# Generate strong URL-safe secrets, e.g.:  openssl rand -hex 32

# ----- Runtime -----
NODE_ENV=production

# ----- PostgreSQL -----
POSTGRES_USER=mepa
POSTGRES_DB=mepa
# Generated and persisted automatically by Coolify for compose.yaml.
SERVICE_PASSWORD_POSTGRES=__CHANGE_ME__
# The app builds DATABASE_URL from the above in compose.yaml. For local host runs:
DATABASE_URL=postgresql://mepa:mepa@127.0.0.1:5432/mepa

# ----- Sessions -----
SESSION_TTL_HOURS=168

# ----- S3-compatible object storage (MinIO by default) -----
# For local host development, point at the dev MinIO: http://127.0.0.1:9000
S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_BUCKET=mepa-media
# Generated and persisted automatically by Coolify for compose.yaml.
SERVICE_USER_MINIO=__CHANGE_ME__
SERVICE_PASSWORD_MINIO=__CHANGE_ME__
S3_FORCE_PATH_STYLE=true

# ----- Future AI tutor (disabled by default; no vendor SDK shipped) -----
TUTOR_ENABLED=false

# ----- Deployment image tagging (compose.yaml / Coolify) -----
APP_IMAGE=mepa-app
APP_TAG=latest
NODE_VERSION=22.14.0-bookworm-slim

# Generated and managed by Coolify. Do not set this for local development.
# SERVICE_FQDN_APP_3000=/

# ----- Backups -----
BACKUP_RETENTION_DAYS=14
BACKUP_INTERVAL_SECONDS=86400
